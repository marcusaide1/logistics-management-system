# Root environment configuration for local development and Docker Compose
# Copy this file to .env and update values before running the app.

# Local PostgreSQL credentials used by docker-compose.yml
POSTGRES_USER=logistics_user
POSTGRES_PASSWORD=logistics_password
POSTGRES_DB=logistics_db

# Prisma backend database URL
# Local SQLite for development (no Docker needed):
DATABASE_URL="file:./dev.db"

# Cloud Postgres example (replace with your cloud DB host and credentials):
# DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require"

# Backend server configuration
JWT_SECRET=change-me-in-prod
CORS_ORIGIN=http://localhost:5173
PORT=8080

# AI Chat widget configuration
# Get your API key from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Password reset email delivery
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASS=your-smtp-password
EMAIL_FROM="Logistics App <no-reply@logistics-app.local>"
RESET_PASSWORD_URL_BASE=http://localhost:5173

# Optional: Twilio for WhatsApp integration
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
